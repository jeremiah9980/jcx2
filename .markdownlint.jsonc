{
  // Extend the default ruleset with project-specific relaxations.
  "default": true,
  // MD013 – line length: disable to avoid noise on existing prose files
  "MD013": false,
  // MD033 – inline HTML: allow since this repo contains mixed HTML/MD
  "MD033": false,
  // MD041 – first line must be top-level heading: relax for README sections
  "MD041": false
}
