{
  "extends": ["html-validate:recommended"],
  "rules": {
    "require-sri": "off",
    "no-inline-style": "off",
    "no-trailing-whitespace": "off",
    "void-style": "off",
    "no-implicit-button-type": "off",
    "element-required-attributes": "off",
    "prefer-native-element": "off",
    "wcag/h32": "off",
    "wcag/h36": "off",
    "wcag/h37": "off"
  }
}
